# ==============================================================================
# AarogyaVaani Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ------------------------------------------------------------------------------
# OpenAI Configuration (Required)
# ------------------------------------------------------------------------------
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Override the OpenAI models used
# OPENAI_MODEL=gpt-4o-mini        # Used for fast dialogue generation
# OPENAI_SCORING_MODEL=gpt-4o     # Used for Chain-of-Thought scoring
